{
  "name": "api-olx",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/api-olx.exe",
    "build:mac:intel": "pkg . --targets node18-macos-x64 --output dist/api-olx-mac-intel",
    "build:mac:arm": "pkg . --targets node18-macos-arm64 --output dist/api-olx-mac-arm"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "src/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "18": "^0.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "pkg": "^5.8.1"
  }
}
